<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1A1A"
    android:padding="20dp"
    android:clipToPadding="false">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#333333"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/txtModalTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Formulir Data Atlet"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/modalImUpload"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:layout_gravity="center_horizontal"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_camera"
        app:strokeColor="#FF1E27"
        app:strokeWidth="2dp"
        app:shapeAppearanceOverlay="@style/CircleImage"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ketuk untuk memilih foto profil"
        android:textColor="#888888"
        android:textSize="11sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/modalEdMemberId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:importantForAutofill="no"
        android:inputType="text" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorHint="#666666"
        app:hintTextColor="#FF1E27"
        android:layout_marginBottom="10dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/modalEdFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nama Lengkap"
            android:textColor="#FFFFFF"
            android:backgroundTint="#262626"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorHint="#666666"
        app:hintTextColor="#FF1E27"
        android:layout_marginBottom="10dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/modalEdEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email"
            android:textColor="#FFFFFF"
            android:backgroundTint="#262626"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorHint="#666666"
        app:hintTextColor="#FF1E27"
        android:layout_marginBottom="10dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/modalEdPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nomor Telepon"
            android:inputType="phone"
            android:textColor="#FFFFFF"
            android:backgroundTint="#262626"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/modalLayoutExpired"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorHint="#666666"
        app:hintTextColor="#FF1E27"
        android:layout_marginBottom="20dp"
        android:visibility="gone">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/modalEdExpiredAt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masa Aktif Berakhir Pada"
            android:textColor="#FF1E27"
            android:textStyle="bold"
            android:focusable="false"
            android:clickable="false"
            android:backgroundTint="#262626"/>
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/modalBtnSubmit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="SIMPAN"
            android:backgroundTint="#FF1E27"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/modalBtnRenew"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="PERPANJANG 1 BULAN"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/modalBtnDelete"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="HAPUS MEMBER"
            android:backgroundTint="#8B0000"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:visibility="gone"/>
    </LinearLayout>
</LinearLayout>