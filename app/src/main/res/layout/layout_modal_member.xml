<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1E1E1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="#444444"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/txtModalTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah Member Baru"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/modalImUpload"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:src="@android:color/darker_gray"
            android:scaleType="centerCrop"
            android:layout_marginBottom="12dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"/>

        <ImageView
            android:id="@+id/modalIvQrCode"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:layout_marginVertical="12dp"
            android:padding="8dp"
            android:background="#FFFFFF"
            android:visibility="gone" />

        <android.widget.EditText
            android:id="@+id/modalEdMemberId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:inputType="none"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nama Lengkap"
            android:textColorHint="#888888"
            app:hintTextColor="#FF1E27"
            app:boxStrokeColor="#FF1E27"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/modalEdFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="textPersonName"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Alamat Email"
            android:textColorHint="#888888"
            app:hintTextColor="#FF1E27"
            app:boxStrokeColor="#FF1E27"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/modalEdEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="textEmailAddress"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nomor Telepon"
            android:textColorHint="#888888"
            app:hintTextColor="#FF1E27"
            app:boxStrokeColor="#FF1E27"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/modalEdPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:inputType="phone"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/modalLayoutExpired"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masa Berlaku Aktif"
            android:textColorHint="#888888"
            app:boxStrokeColor="#888888"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/modalEdExpiredAt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:focusable="false"
                android:clickable="false"
                android:inputType="none"/>
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/modalBtnSubmit"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="SIMPAN DATA"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF1E27"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/modalBtnRenew"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:text="PERPANJANG"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00E676"
                android:textStyle="bold"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/modalBtnDelete"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:text="HAPUS MEMBER"
                android:textColor="#FFFFFF"
                android:backgroundTint="#333333"
                android:textStyle="bold"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>