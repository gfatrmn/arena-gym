<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="40dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ARENA GYM • EXECUTIVE REPORT"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Laporan Keuangan"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/edReportStartDate"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="#1E1E1E"
                    android:hint="Dari Tanggal"
                    android:textColorHint="#555555"
                    android:textColor="#FFFFFF"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:focusable="false"
                    android:clickable="true"/>

                <EditText
                    android:id="@+id/edReportEndDate"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="#1E1E1E"
                    android:hint="Sampai Tanggal"
                    android:textColorHint="#555555"
                    android:textColor="#FFFFFF"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:focusable="false"
                    android:clickable="true"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnExportExcel"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="📊 EXPORT LAPORAN KE EXCEL"
                android:backgroundTint="#00E676"
                android:textColor="#121212"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"
                app:cornerRadius="8dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1E1E1E"
                    app:cardCornerRadius="8dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL MEMBER" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/txtRepTotalMember" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1E1E1E"
                    app:cardCornerRadius="8dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CHECK-IN PERIODE" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/txtRepTotalCheckIn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#00E676" android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1E1E1E"
                    app:cardCornerRadius="8dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PENDAPATAN" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/txtRepIncomeToday" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp0" android:textColor="#FF1E27" android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1E1E1E"
                    app:cardCornerRadius="8dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL PENDAPATAN" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/txtRepIncomeAll" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rp0" android:textColor="#FFFF00" android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TREN PENDAPATAN BULANAN"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="24dp">

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChartReport"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="12dp"/>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="LOG OUT"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#FF1E27"
                app:cornerRadius="8dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>