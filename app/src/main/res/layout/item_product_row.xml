<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="8dp"
    app:strokeWidth="0dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:weightSum="4">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2.6"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtProdName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Produk"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtProdCatBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori • Brand"
                android:textColor="#888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtProdStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stok: 0 pcs"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.4"
            android:orientation="vertical"
            android:gravity="end|center_vertical">

            <TextView
                android:id="@+id/txtProdPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp0"
                android:textColor="#FF1E27"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/btnProdEdit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EDIT"
                    android:textColor="#00E676"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:padding="4dp"
                    android:layout_marginRight="8dp"/>

                <TextView
                    android:id="@+id/btnProdDelete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HAPUS"
                    android:textColor="#FF5252"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:padding="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>