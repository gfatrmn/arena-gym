<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ARENA GYM • RIWAYAT CHECK-IN"
                android:textColor="#888888"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Check-In"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <RadioGroup
                android:id="@+id/rgCheckInType"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:orientation="horizontal"
                android:background="#1E1E1E"
                android:padding="4dp"
                android:layout_marginBottom="24dp">

                <RadioButton
                    android:id="@+id/rbTypeMember"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:button="@null"
                    android:checked="true"
                    android:gravity="center"
                    android:text="MEMBER"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <RadioButton
                    android:id="@+id/rbTypeNonMember"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:button="@null"
                    android:gravity="center"
                    android:text="NON-MEMBER"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </RadioGroup>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 1. FORM UNTUK MEMBER (DIPERBAIKI) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutInputMember"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ketik Nama Member"
                        android:textColorHint="#888888"
                        app:hintTextColor="#AAAAAA"
                        app:boxStrokeColor="#888888"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        android:visibility="visible"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <AutoCompleteTextView
                            android:id="@+id/autoCompleteMemberAuto"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:padding="16dp"
                            android:completionThreshold="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- 2. FORM UNTUK NON-MEMBER (DIPERBAIKI) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutInputNonMemberName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nama Pengunjung Harian"
                        android:textColorHint="#888888"
                        app:hintTextColor="#AAAAAA"
                        app:boxStrokeColor="#888888"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        android:visibility="gone"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edNonMemberName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:padding="16dp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnSubmitCheckIn"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="KONFIRMASI CHECK-IN"
                        android:backgroundTint="#FF1E27"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="24dp"
                        app:cornerRadius="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOG KUNJUNGAN HARI INI"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="8dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3"
                        android:paddingBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.3" android:text="NAMA" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TIPE" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.7" android:text="WAKTU" android:textColor="#888888" android:textSize="10sp" android:textStyle="bold" android:gravity="end"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#333333"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:id="@+id/containerCheckInLogs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:menu="@menu/bottom_nav_menu"
        android:elevation="12dp"
        app:labelVisibilityMode="labeled"
        app:itemIconSize="22dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>